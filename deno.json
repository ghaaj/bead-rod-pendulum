{
  "tasks": {
    "dev": "deno run --node-modules-dir -A npm:vite",
    "build": "deno run --node-modules-dir -A npm:vite build",
    "preview": "deno run --node-modules-dir -A npm:vite preview"
  },
  "imports": {
    "@tweakpane/core": "npm:@tweakpane/core@^2.0.5",
    "p5": "npm:p5@^2.2.2",
    "tweakpane": "npm:tweakpane@^4.0.5"
  },
  "fmt": {
    "lineWidth": 100
  },
  "compilerOptions": {
    "lib": ["deno.ns", "dom", "dom.iterable"],
    "verbatimModuleSyntax": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedIndexedAccess": true
  }
}
